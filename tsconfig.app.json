{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    
    "noEmit": true,
    "paths": {
      "@/*": ["./apps/frontend/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "apps/frontend/**/*.ts",
    "apps/frontend/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
