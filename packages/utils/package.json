{
  "name": "@packages/utils",
  "version": "1.0.0",
  "description": "MultiAgent Shared Utility Mesh",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/tsup/dist/cli-default.js src/index.ts --format cjs,esm --no-dts",
    "dev": "node ../../node_modules/tsup/dist/cli-default.js src/index.ts --format cjs,esm --no-dts --watch"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1038.0",
    "@packages/config": "workspace:*",
    "@packages/db": "workspace:*",
    "@packages/events": "workspace:*",
    "@packages/observability": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "bullmq": "^5.71.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "tailwind-merge": "^2.6.1",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
