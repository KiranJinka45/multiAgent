    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.13.9",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
