{
  "name": "@libs/core-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libs/contracts": "workspace:*",
    "@libs/agents": "workspace:*",
    "@libs/brain": "workspace:*",
    "@libs/utils": "workspace:*",
    "@libs/runtime": "workspace:*",
    "@libs/validator": "workspace:*",
    "@libs/registry": "workspace:*",
    "fs-extra": "^11.3.4",
    "ioredis": "^5.10.1",
    "bullmq": "^5.70.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  }
}
