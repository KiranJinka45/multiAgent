{
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declarationMap": true,
    "declaration": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@packages/contracts": [
        "../contracts/src"
      ],
      "@packages/observability": [
        "../observability/src"
      ],
      "@packages/core-engine": [
        "../core-engine/src"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "extends": "../../tsconfig.base.json",
  "references": [
    {
      "path": "../contracts"
    },
    {
      "path": "../core-engine"
    },
    {
      "path": "../observability"
    }
  ]
}