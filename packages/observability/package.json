{
  "name": "@libs/observability",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libs/utils": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "latest",
    "@opentelemetry/exporter-otlp-http": "latest",
    "@opentelemetry/sdk-trace-base": "latest",
    "@opentelemetry/sdk-trace-node": "latest",
    "@opentelemetry/resources": "latest",
    "@opentelemetry/sdk-node": "latest",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "pino": "^10.3.1",
    "@opentelemetry/semantic-conventions": "latest",
    "@opentelemetry/api": "latest"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  }
}
