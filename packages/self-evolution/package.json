    "@packages/observability": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
