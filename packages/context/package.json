{
    "name":  "@packages/context",
    "version":  "0.1.0",
    "private":  true,
    "main":  "./dist/index.js",
    "module":  "./dist/index.mjs",
    "types":  "./src/index.ts",
    "exports":  {
                    ".":  {
                              "types":  "./src/index.ts",
                              "import":  "./dist/index.mjs",
                              "require":  "./dist/index.js",
                              "default":  "./dist/index.js"
                          },
                    "./*":  {
                                "types":  "./src/*.ts",
                                "import":  "./dist/*.js",
                                "default":  "./dist/*.js"
                            }
                },
    "dependencies":  {
                         "@packages/utils":  "workspace:*",
                         "@packages/contracts":  "workspace:*",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1"
                     },
    "devDependencies":  {
                            "tsup":  "^8.5.1",
                            "typescript":  "^5"
                        },
    "scripts":  {
                    "build":  "tsup --config tsup.config.js",
                    "dev":  "tsup --watch",
                    "lint":  "eslint .",
                    "typecheck":  "tsc --noEmit"
                }
}
