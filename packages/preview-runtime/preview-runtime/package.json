{
  "name": "@packages/runtime",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "module": "./dist/index.mjs",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --external @/* --external @packages/* --format cjs,esm",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@packages/utils": "workspace:*",
    "@packages/registry": "workspace:*",
    "@packages/validator": "workspace:*",
    "@packages/contracts": "workspace:*",
    "fs-extra": "^11.2.0",
    "ioredis": "^5.10.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}