{
    "extends":  "../../tsconfig.base.json",
    "exclude":  [
                    "node_modules",
                    "dist"
                ],
    "include":  [
                    "src/**/*"
                ],
    "compilerOptions":  {
                            "composite":  true,
                            "outDir":  "dist",
                            "noEmit":  false,
                            "declarationMap":  true,
                            "declaration":  true,
                            "rootDir":  "src"
                        },
    "references":  [
                       {
                           "path":  "..//utils"
                       },
                       {
                           "path":  "..//registry"
                       },
                       {
                           "path":  "..//validator"
                       },
                       {
                           "path":  "..//contracts"
                       }
                   ]
}
