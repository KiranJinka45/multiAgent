{
  "name": "@packages/sandbox-cluster",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./cluster": {
      "types": "./dist/cluster.d.ts",
      "import": "./dist/cluster.js",
      "require": "./dist/cluster.cjs"
    }
  },
  "dependencies": {
    "@packages/utils": "workspace:*",
    "@packages/registry": "workspace:*",
    "@packages/validator": "workspace:*",
    "fs-extra": "^11.2.0",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1"
  }
}
