{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "es2020",
      "es2021",
      "es2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./apps/frontend/*"
      ],
      "@/services/*": [
        "./apps/api-gateway/services/*",
        "./libs/shared-services/*"
      ],
      "@/types/*": [
        "./libs/shared-types/*"
      ],
      "@app/*": [
        "./apps/frontend/app/*"
      ],
      "@components/*": [
        "./apps/frontend/components/*"
      ],
      "@agents/*": [
        "./libs/agents/*"
      ],
      "@workers/*": [
        "./apps/worker/*"
      ],
      "@queue": [
        "./libs/shared-services/queue/index.ts"
      ],
      "@queue/*": [
        "./libs/shared-services/queue/*"
      ],
      "@services/*": [
        "./apps/api-gateway/services/*",
        "./libs/shared-services/*"
      ],
      "@shared/*": [
        "./libs/shared-utils/*"
      ],
      "@shared/services/*": [
        "./libs/shared-services/*"
      ],
      "@shared/types/*": [
        "./libs/shared-types/*"
      ],
      "@services/orchestrator": [
        "./apps/api-gateway/services/orchestrator.ts"
      ],
      "@libs/*": [
        "./libs/*"
      ],
      "@config/*": [
        "./libs/shared-utils/config/*"
      ],
      "@templates/*": [
        "./libs/templates/*"
      ],
      "@shared-types/*": [
        "./libs/shared-types/*"
      ],
      "@runtime/*": [
        "./apps/preview-runtime/*"
      ],
      "@registry/*": [
        "./libs/registry/*"
      ],
      "@build-engine/*": [
        "./libs/build-engine/*"
      ],
      "@validator/*": [
        "./libs/validator/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "templates",
    "tmp",
    ".next"
  ]
}
