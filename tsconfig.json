{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "es2020",
      "es2021",
      "es2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@app/*": [
        "./app/*"
      ],
      "@components/*": [
        "./components/*"
      ],
      "@agents/*": [
        "./agents/*"
      ],
      "@services/*": [
        "./services/*"
      ],
      "@workers/*": [
        "./workers/*"
      ],
      "@queue": [
        "./services/queue/index.ts"
      ],
      "@queue/*": [
        "./services/queue/*"
      ],
      "@services/orchestrator": [
        "./services/orchestrator.ts"
      ],
      "@services/event-bus": [
        "./services/event-bus.ts"
      ],
      "@services/build-state": [
        "./services/build-state.ts"
      ],
      "@lib/*": [
        "./lib/*"
      ],
      "@config/*": [
        "./config/*"
      ],
      "@templates/*": [
        "./templates/*"
      ],
      "@shared-types/*": [
        "./types/*"
      ],
      "@runtime/*": [
        "./runtime/*"
      ],
      "@services/engines/*": [
        "./services/engines/*"
      ],
      "@services/agent-intelligence/*": [
        "./services/agent-intelligence/*"
      ],
      "@services/learning/*": [
        "./services/learning/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "templates",
    "tmp",
    ".next",
    "scripts"
  ]
}
