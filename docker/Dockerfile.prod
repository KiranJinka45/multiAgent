# Multi-Stage Build for Monorepo
FROM node:20-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable
WORKDIR /app

# Stage 1: Prune Workspace
FROM base AS pruner
ARG APP_NAME
COPY . .
RUN pnpm --filter @apps/${APP_NAME} deploy --prod ./out

# Stage 2: Final Runner Image
FROM node:20-slim AS runner
WORKDIR /app
ARG APP_NAME

# Create non-root user
RUN groupadd -r clouduser && useradd -r -g clouduser clouduser
COPY --from=pruner /app/out/node_modules ./node_modules
COPY --from=pruner /app/out/dist ./dist
COPY --from=pruner /app/out/package.json ./package.json

USER clouduser
ENV NODE_ENV=production
ENV PORT=4000

EXPOSE 4000
CMD ["node", "dist/index.js"]
