{
  "name": "multiagent-enterprise",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Enterprise-grade Microservices MultiAgent Cluster",
  "scripts": {
    "predev": "tsx scripts/cleanup.ts && tsx scripts/preflight.ts && tsx scripts/port-check.ts",
    "dev": "pnpm run predev && tsx scripts/start-dev.ts",
    "build": "turbo build",
    "start:api": "node apps/api/dist/index.js",
    "start:worker": "node apps/worker/dist/index.js",
    "db:push": "npx prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:seed": "echo 'No seed script available'",
    "postinstall": "node scripts/prisma-generate-safe.js --skip-if-exists",
    "test:chaos": "tsx test/integration/chaos-test.ts",
    "test:certify": "tsx test/integration/causal-certification.ts",
    "test:certify:trust": "tsx test/integration/trust-hitl-certification.ts",
    "test:pulse": "tsx test/integration/platform-pulse.ts",
    "test:safety": "tsx test/security/test-safety.ts",
    "test:e2e": "tsx test/integration/e2e-validation.ts",
    "audit:cost": "tsx scripts/audit-cost-roi.ts",
    "orchestrate": "tsx scripts/dev-orchestrator.ts",
    "dev:all": "tsx scripts/dev-orchestrator.ts",
    "validate:cloud": "tsx scripts/validate-cloud.ts"
  },
  "prisma": {
    "schema": "packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/middleware-flexible-checksums": "^3.974.16",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.7",
    "chalk": "^5.6.2",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "commander": "^14.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "etcd3": "^1.1.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@packages/queue": "workspace:*",
    "@packages/utils": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "nock": "^14.0.12",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.18",
      "@types/react-dom": "^18.3.5",
      "@types/express": "^5.0.0",
      "@types/express-serve-static-core": "^5.0.0",
      "express": "^5.2.1"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "blake-hash",
      "cpu-features",
      "esbuild",
      "leveldown",
      "lmdb",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp",
      "ssh2"
    ],
    "ignoredBuiltDependencies": [
      "bcrypt"
    ]
  }
}