{
  "name": "multiagent-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:apps": "turbo run dev --filter=apps/*",
    "build": "turbo run build",
    "build:analyze": "turbo run build && npx source-map-explorer apps/gateway/dist/index.js",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prebuild": "node scripts/verify-reliability.js",
    "boot": "node scripts/system-startup.js",
    "start:deploy": "npm --prefix apps/deploy-service run start",
    "check:deps": "depcruise --config .dependency-cruiser.js packages",
    "graph": "madge --image graph.png packages",
    "refactor": "pnpm --filter @libs/refactor-agent run build && node packages/refactor-agent/dist/index.js",
    "autonomous": "pnpm --filter @libs/autonomous-agent run build && node packages/autonomous-agent/dist/cli.js"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "dependency-cruiser": "^17.3.9",
    "eslint-plugin-boundaries": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.10.0",
    "source-map-explorer": "^2.5.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}