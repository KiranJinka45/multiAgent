{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {

      "@packages/ai": ["packages/ai/src"],
      "@packages/ai/*": ["packages/ai/src/*"],
      "@packages/brain": ["packages/brain/src"],
      "@packages/brain/*": ["packages/brain/src/*"],
      "@packages/build-engine": ["packages/build-engine/src"],
      "@packages/build-engine/*": ["packages/build-engine/src/*"],
      "@packages/context": ["packages/context/src"],
      "@packages/context/*": ["packages/context/src/*"],
      "@packages/contracts": ["packages/contracts/src"],
      "@packages/contracts/*": ["packages/contracts/src/*"],

      "@packages/db": ["packages/db/src/index.ts"],
      "@packages/memory": ["packages/memory/src"],
      "@packages/memory/*": ["packages/memory/src/*"],
      "@packages/memory-core": ["packages/memory-core/src"],
      "@packages/memory-core/*": ["packages/memory-core/src/*"],
      "@packages/memory-vector": ["packages/memory-vector/src"],
      "@packages/memory-vector/*": ["packages/memory-vector/src/*"],
      "@packages/memory-cache": ["packages/memory-cache/src"],
      "@packages/memory-cache/*": ["packages/memory-cache/src/*"],
      "@packages/registry": ["packages/registry/src"],
      "@packages/registry/*": ["packages/registry/src/*"],
      "@packages/runtime": ["apps/preview-runtime/src"],
      "@packages/runtime/*": ["apps/preview-runtime/src/*"],
      "@packages/sandbox-runtime": ["apps/sandbox-runtime/src"],
      "@packages/sandbox-runtime/*": ["apps/sandbox-runtime/src/*"],
      "@packages/sdk": ["packages/sdk/src"],
      "@packages/sdk/*": ["packages/sdk/src/*"],
      "@packages/shared-services": ["packages/shared-services/src"],
      "@packages/shared-services/*": ["packages/shared-services/src/*"],
      "@packages/supabase": ["packages/supabase/src"],
      "@packages/supabase/*": ["packages/supabase/src/*"],
      "@packages/templates": ["packages/templates/src"],
      "@packages/templates/*": ["packages/templates/src/*"],
      "@packages/tools": ["packages/tools/src"],
      "@packages/tools/*": ["packages/tools/src/*"],
      "@packages/ui": ["packages/ui/src"],
      "@packages/ui/*": ["packages/ui/src/*"],
      "@packages/utils": ["packages/utils/src"],
      "@packages/utils/*": ["packages/utils/src/*"],
      "@packages/utils/server": ["packages/utils/src/server/index.ts"],
      "@packages/utils/server/*": ["packages/utils/src/server/*"],
      "@packages/lib/*": ["packages/utils/src/lib/*"],
      "@packages/config/*": ["packages/utils/src/config/*"],
      "@packages/observability": ["packages/observability/src"],
      "@packages/observability/*": ["packages/observability/src/*"],
      "@packages/resilience": ["packages/resilience/src"],
      "@packages/resilience/*": ["packages/resilience/src/*"],
      "@apps/sandbox-runtime": ["apps/sandbox-runtime/src"],
      "@apps/sandbox-runtime/*": ["apps/sandbox-runtime/src/*"],
      "@apps/runtime": ["apps/preview-runtime/src"],
      "@apps/runtime/*": ["apps/preview-runtime/src/*"],
      "@packages/*/package.json": ["packages/*/package.json"],

      "@packages/agents": ["packages/agents/src"],
      "@packages/agents/*": ["packages/agents/src/*"],
      "@packages/core-engine": ["packages/core-engine/src"],
      "@packages/core-engine/*": ["packages/core-engine/src/*"],
      "@packages/validator": ["packages/validator/src"],
      "@packages/validator/*": ["packages/validator/src/*"],
      "@packages/auto-healer": ["packages/auto-healer/src"],
      "@packages/auto-healer/*": ["packages/auto-healer/src/*"],
      "@packages/sandbox": ["packages/sandbox/src"],
      "@packages/sandbox/*": ["packages/sandbox/src/*"],
      "@packages/queue": ["packages/queue/src"],
      "@packages/queue/*": ["packages/queue/src/*"],
      "@config/*": ["packages/utils/src/config/*"],
      "@utils/*": ["packages/utils/src/services/*"],
      "@queue": ["packages/utils/src/services/redis.ts"],
      "@shared/*": ["packages/utils/src/*"]
    }
  }
}
