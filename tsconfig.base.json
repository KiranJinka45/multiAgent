{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@libs/agents": ["packages/agents/src"],
      "@libs/ai": ["packages/ai/src"],
      "@libs/brain": ["packages/brain/src"],
      "@libs/build-engine": ["packages/build-engine/src"],
      "@libs/context": ["packages/context/src"],
      "@libs/contracts": ["packages/contracts/src"],
      "@libs/core-engine": ["packages/core-engine/src"],
      "@libs/db": ["packages/db/src/index.ts"],
      "@libs/memory": ["packages/memory/src"],
      "@libs/memory-core": ["packages/memory-core/src"],
      "@libs/memory-vector": ["packages/memory-vector/src"],
      "@libs/memory-cache": ["packages/memory-cache/src"],
      "@libs/observability": ["packages/observability/src"],
      "@libs/registry": ["packages/registry/src"],
      "@libs/runtime": ["apps/preview-runtime/src"],
      "@libs/runtime/*": ["apps/preview-runtime/src/*"],
      "@libs/sdk": ["packages/sdk/src"],
      "@libs/shared-services": ["packages/shared-services/src"],
      "@libs/supabase": ["packages/supabase/src"],
      "@libs/templates": ["packages/templates/src"],
      "@libs/tools": ["packages/tools/src"],
      "@libs/ui": ["packages/ui/src"],
      "@libs/utils": ["packages/utils/src"],
      "@libs/utils/*": ["packages/utils/src/*"],
      "@libs/validator": ["packages/validator/src"]
    }
  }
}
