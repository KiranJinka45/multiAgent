{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@components/*": ["./components/*"],
      "@packages/utils/*": ["../../packages/utils/src/*"],
      "@packages/context/*": ["../../packages/context/src/*"],
      "@packages/shared-services/*": ["../../packages/shared-services/src/*"],
      "@packages/db/*": ["../../packages/db/src/*"],
      "@packages/observability/*": ["../../packages/observability/src/*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*",
    "app/**/*",
    "components/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
