{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@app/*": ["./app/*"],
      "@components/*": ["./components/*"],
      "@services/*": ["../../apps/api-gateway/services/*", "../../libs/shared-services/*"],
      "@types/*": ["../../libs/shared-types/*"],
      "@context/*": ["../../libs/context/*"],
      "@shared/*": ["../../libs/shared-utils/*"],
      "@shared-types/*": ["../../libs/shared-types/*"],
      "@libs/*": ["../../libs/*"],
      "@config/*": ["../../libs/shared-utils/config/*"],
      "@hooks/*": ["../../libs/shared-utils/hooks/*"],
      "@lib/*": ["../../libs/shared-utils/lib/*"],
      "@queue": ["../../libs/shared-services/queue/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
