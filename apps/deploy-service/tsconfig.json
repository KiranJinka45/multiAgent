{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "skipLibCheck": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "baseUrl": ".",
    "paths": {
      "@packages/db": [
        "../../packages/db/src"
      ],
      "@packages/utils": [
        "../../packages/utils/src"
      ],
      "@packages/observability": [
        "../../packages/observability/src"
      ],
      "@packages/contracts": [
        "../../packages/contracts/src"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../../packages/contracts"
    },
    {
      "path": "../../packages/db"
    },
    {
      "path": "../../packages/observability"
    },
    {
      "path": "../../packages/utils"
    }
  ]
}