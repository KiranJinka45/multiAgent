# ============================================================
# Sandbox Dockerfile for generated project previews
#
# Multi-stage: installs deps in builder, copies to slim runtime.
# Enforced: non-root user, read-only FS (except /app and /tmp),
# built-in HEALTHCHECK for Docker-native crash detection.
# ============================================================

FROM node:20-alpine AS builder

WORKDIR /build

# Copy generated project files (mounted by containerManager)
COPY . .

# Install dependencies and build
RUN npm ci --prefer-offline --no-audit --no-fund 2>/dev/null || npm install --prefer-offline --no-audit --no-fund
RUN npm run build 2>/dev/null || true

# ──────────────────────────────────────────────────────────────
FROM node:20-alpine AS runtime

# Security: run as non-root
RUN addgroup -S sandbox && adduser -S sandbox -G sandbox

WORKDIR /app

# Copy built project from builder
COPY --from=builder --chown=sandbox:sandbox /build /app

# Healthcheck: curl the dev server every 30s, 5s timeout, 3 retries
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD wget --spider --quiet http://localhost:${PORT:-3000}/ || exit 1

# Metadata labels
LABEL maintainer="multiagent-platform"
LABEL purpose="preview-sandbox"

# Expose the dynamic port (overridden at runtime via -e PORT=xxxx)
EXPOSE ${PORT:-3000}

# Drop to non-root user
USER sandbox

# Default command — overridden by containerManager if needed
CMD ["npm", "run", "dev"]
